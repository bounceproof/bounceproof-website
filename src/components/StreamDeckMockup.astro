---
const labels = [
  'ORDER', 'EMAIL', 'PAYMT', 'SHIP', 'INVOICE', 'SYNC', 'BATCH', 'CRON', 'TRANSFER',
  'WEBHOOK', 'EXPORT', 'IMPORT', 'REFUND', 'NOTIFY', 'RENEW', 'BACKUP', 'INDEX', 'VALIDATE',
  'QUEUE', 'RETRY', 'AUDIT', 'REPORT', 'PURGE', 'SCAN', 'VERIFY', 'MERGE', 'CLEANUP',
  'DEPLOY', 'BUILD', 'PUBLISH', 'ARCHIVE', 'ROUTE', 'MATCH', 'SETTLE', 'CLOSE', 'MONITOR',
]

const redIndexes = new Set([5, 13, 22, 27, 33])

const upGraph = '0,22 4,20 8,21 12,16 16,17 20,11 24,12 28,6 32,8 36,3'
const downGraph = '0,4 4,8 8,6 12,12 16,10 20,16 24,15 28,20 32,18 36,23'

const keys = labels.map((label, i) => ({
  label,
  isRed: redIndexes.has(i),
  graph: redIndexes.has(i) ? downGraph : upGraph,
}))

const cols = 9
const rows = 4
const keySize = 70
const gap = 12
const gridStartX = 56
const gridStartY = 56

const gridWidth = cols * keySize + (cols - 1) * gap
const gridHeight = rows * keySize + (rows - 1) * gap

const stripY = gridStartY + gridHeight + 24
const stripHeight = 56
const knobCount = 6
const regionWidth = gridWidth / knobCount

const barColors = ['#22c55e', '#3b82f6', '#eab308', '#a855f7', '#ef4444', '#14b8a6', '#f97316']

function seededRandom(seed: number) {
  let value = seed
  return () => {
    value = (value * 9301 + 49297) % 233280
    return value / 233280
  }
}

const regions = Array.from({ length: knobCount }).map((_, regionIndex) => {
  const rand = seededRandom(regionIndex * 17 + 3)
  const barCount = 7
  return Array.from({ length: barCount }).map(() => ({
    height: 8 + rand() * 32,
    color: barColors[Math.floor(rand() * barColors.length)],
  }))
})

const dialY = stripY + stripHeight + 38
const totalWidth = gridStartX * 2 + gridWidth
const totalHeight = dialY + 50
---

<svg viewBox={`0 0 ${totalWidth} ${totalHeight}`} xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
  <!-- Device body -->
  <rect x="0" y="0" width={totalWidth} height={totalHeight} rx="28" fill="#0a0a0f" stroke="#2e303a" stroke-width="2" />

  <!-- Keys -->
  {keys.map((key, i) => {
    const col = i % cols
    const row = Math.floor(i / cols)
    const x = gridStartX + col * (keySize + gap)
    const y = gridStartY + row * (keySize + gap)
    const bg = key.isRed ? '#3f1d1d' : '#142a1c'
    const border = key.isRed ? '#ef4444' : '#22c55e'
    const textColor = key.isRed ? '#fca5a5' : '#86efac'
    const graphColor = key.isRed ? '#ef4444' : '#22c55e'

    return (
      <g>
        <rect x={x} y={y} width={keySize} height={keySize} rx="10" fill={bg} stroke={border} stroke-width="1.5" />
        <text x={x + keySize / 2} y={y + 18} text-anchor="middle" font-size="8.5" font-family="ui-monospace, monospace" fill={textColor} font-weight="600">
          {key.label}
        </text>
        <g transform={`translate(${x + 6}, ${y + 28})`}>
          <polyline points={key.graph} fill="none" stroke={graphColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.9" />
        </g>
        <circle cx={x + keySize - 9} cy={y + keySize - 9} r="3" fill={key.isRed ? '#ef4444' : '#22c55e'} />
      </g>
    )
  })}

  <!-- Touch strip with 6 bar-chart regions -->
  <rect x={gridStartX} y={stripY} width={gridWidth} height={stripHeight} rx="8" fill="#16171d" stroke="#2e303a" stroke-width="1.5" />
  {regions.map((bars, regionIndex) => {
    const regionX = gridStartX + regionIndex * regionWidth
    const barGap = 4
    const barWidth = (regionWidth - barGap * (bars.length + 1)) / bars.length
    const baseline = stripY + stripHeight - 8

    return (
      <g>
        {regionIndex > 0 && (
          <line x1={regionX} y1={stripY + 6} x2={regionX} y2={stripY + stripHeight - 6} stroke="#2e303a" stroke-width="1" />
        )}
        {bars.map((bar, barIndex) => {
          const bx = regionX + barGap + barIndex * (barWidth + barGap)
          return (
            <rect
              x={bx}
              y={baseline - bar.height}
              width={barWidth}
              height={bar.height}
              rx="1.5"
              fill={bar.color}
              opacity="0.85"
            />
          )
        })}
      </g>
    )
  })}

  <!-- Knobs -->
  {Array.from({ length: knobCount }).map((_, i) => {
    const x = gridStartX + i * regionWidth + regionWidth / 2
    return (
      <g>
        <circle cx={x} cy={dialY} r="20" fill="#16171d" stroke="#2e303a" stroke-width="2" />
        <circle cx={x} cy={dialY} r="3" fill="#4b5563" />
      </g>
    )
  })}
</svg>
