---
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Documentation', href: '/docs' },
  { label: 'Stream Deck XL+', href: '/streamdeck-xl' },
]
---

<header class="fixed top-0 left-0 right-0 h-14 bg-gray-900 border-b border-gray-700 flex items-center px-6 z-50">
  <a href="/" class="flex items-center gap-3">
    <div class="w-8 h-8 rounded bg-green-500 flex items-center justify-center text-white text-xs font-bold">
      BP
    </div>
    <span class="font-semibold text-lg tracking-tight"><span class="text-green-500">BounceProof</span><span class="text-white">.io</span></span>
  </a>

  <nav class="flex-1 flex items-center justify-center gap-8">
    {navItems.map(item => (
      <a href={item.href} class="text-gray-400 hover:text-white text-sm font-medium transition-colors">
        {item.label}
      </a>
    ))}
  </nav>

  <div class="w-[148px]"></div>
</header>
